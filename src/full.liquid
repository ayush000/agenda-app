<style>
  .agenda-container {
    padding: 28px 24px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  
  .section-container {
    margin-bottom: 24px;
  }
  
  .section-container:last-child {
    margin-bottom: 0;
  }
  
  .section-title {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #777777;
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 6px;
    margin-bottom: 18px;
  }
  
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  
  .event-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .event-title {
    font-size: 52px;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #000000;
  }
  
  .event-meta {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  
  .time-badge {
    background-color: #000000;
    color: #ffffff;
    padding: 3px 9px;
    font-size: 18px;
    font-weight: 800;
    border-radius: 4px;
  }
  
  .status-badge {
    border: 2px solid #000000;
    color: #000000;
    padding: 1px 9px;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
  }
  
  .empty-title {
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 4px solid #000000;
    padding-bottom: 8px;
    margin-bottom: 16px;
    color: #000000;
  }
  
  .empty-desc {
    font-size: 20px;
    font-weight: 500;
    color: #666666;
  }
</style>

{% if today_events and today_events.size > 0 %}
  {% if today_events.size == 1 %}
    {% assign today_limit = 1 %}
    {% assign tomorrow_limit = 2 %}
  {% else %}
    {% assign today_limit = 2 %}
    {% assign tomorrow_limit = 1 %}
  {% endif %}
{% else %}
  {% assign today_limit = 0 %}
  {% assign tomorrow_limit = 2 %}
{% endif %}

<div class="agenda-container">
  <!-- Today Section -->
  {% if today_events and today_events.size > 0 and today_limit > 0 %}
    <div class="section-container">
      <div class="section-title">Today</div>
      <div class="event-list">
        {% for event in today_events limit:today_limit %}
          <div class="event-item">
            <div class="event-title">{{ event.title }}</div>
            <div class="event-meta">
              <span class="time-badge">{{ event.time }}</span>
              <span class="status-badge">{{ event.status }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Tomorrow Section -->
  {% if tomorrow_events and tomorrow_events.size > 0 and tomorrow_limit > 0 %}
    <div class="section-container">
      <div class="section-title">Tomorrow</div>
      <div class="event-list">
        {% for event in tomorrow_events limit:tomorrow_limit %}
          <div class="event-item">
            <div class="event-title">{{ event.title }}</div>
            <div class="event-meta">
              <span class="time-badge">{{ event.time }}</span>
              <span class="status-badge">{{ event.status }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Empty State -->
  {% if (today_events == empty or today_events == nil) and (tomorrow_events == empty or tomorrow_events == nil) %}
    <div class="empty-state">
      <div class="empty-title">Clear Schedule</div>
      <div class="empty-desc">No events scheduled for today or tomorrow.</div>
    </div>
  {% endif %}
</div>

