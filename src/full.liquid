<style>
  .section-label { text-transform: uppercase; letter-spacing: 0.12em; }
</style>

{% assign total_slots = 6 %}

{% assign today_size = 0 %}
{% if today_events %}
  {% assign today_size = today_events.size %}
{% endif %}

{% if today_size >= total_slots %}
  {% assign today_limit = total_slots %}
  {% assign tomorrow_limit = 0 %}
{% else %}
  {% assign today_limit = today_size %}
  {% assign tomorrow_limit = total_slots | minus: today_limit %}
{% endif %}

<div class="layout layout--col layout--start layout--stretch-x">
  {% if today_events and today_events.size > 0 and today_limit > 0 %}
    <div class="description section-label label--gray-out">Today</div>
    <div class="divider--h"></div>
    {% for event in today_events limit:today_limit %}
      <div class="flex flex--row flex--between flex--center-y">
        <div class="value--large flex-auto">{{ event.summary }}</div>
        <span class="label label--inverted label--xxlarge flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
      </div>
    {% endfor %}
  {% endif %}

  {% if tomorrow_events and tomorrow_events.size > 0 and tomorrow_limit > 0 %}
    <div class="description section-label label--gray-out">Tomorrow</div>
    <div class="divider--h"></div>
    {% for event in tomorrow_events limit:tomorrow_limit %}
      <div class="flex flex--row flex--between flex--center-y">
        <div class="value--large flex-auto">{{ event.summary }}</div>
        <span class="label label--inverted label--xxlarge flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
      </div>
    {% endfor %}
  {% endif %}

  {% assign today_empty = false %}
  {% if today_events == empty or today_events == nil or today_events.size == 0 %}
    {% assign today_empty = true %}
  {% endif %}

  {% assign tomorrow_empty = false %}
  {% if tomorrow_events == empty or tomorrow_events == nil or tomorrow_events.size == 0 %}
    {% assign tomorrow_empty = true %}
  {% endif %}

  {% if today_empty and tomorrow_empty %}
    <div class="flex flex--col">
      <div class="title--xxlarge section-label">Clear Schedule</div>
      <div class="description">No events scheduled for today or tomorrow.</div>
    </div>
  {% endif %}
</div>
