<style>
  .agenda-container {
    padding: 28px 24px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  
  .section-container {
    margin-bottom: 20px;
  }
  
  .section-container:last-child {
    margin-bottom: 0;
  }
  
  .section-title {
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #777777;
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 6px;
    margin-bottom: 12px;
  }
  
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  
  .event-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  
  .event-title {
    font-size: 53px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #000000;
    flex-grow: 1;
  }
  
  .time-badge {
    background-color: #000000;
    color: #ffffff;
    padding: 3px 9px;
    font-size: 28px;
    font-weight: 800;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
  }
  
  .empty-title {
    font-size: 50px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 4px solid #000000;
    padding-bottom: 8px;
    margin-bottom: 16px;
    color: #000000;
  }
  
  .empty-desc {
    font-size: 28px;
    font-weight: 500;
    color: #666666;
  }
</style>

{% assign total_slots = 6 %}

{% assign today_size = 0 %}
{% if today_events %}
  {% assign today_size = today_events.size %}
{% endif %}

{% if today_size >= total_slots %}
  {% assign today_limit = total_slots %}
  {% assign tomorrow_limit = 0 %}
{% else %}
  {% assign today_limit = today_size %}
  {% assign tomorrow_limit = total_slots | minus: today_limit %}
{% endif %}

<div class="agenda-container">
  <!-- Today Section -->
  {% if today_events and today_events.size > 0 and today_limit > 0 %}
    <div class="section-container">
      <div class="section-title">Today</div>
      <div class="event-list">
        {% for event in today_events limit:today_limit %}
          <div class="event-item">
            <div class="event-title">{{ event.title }}</div>
            <span class="time-badge">{{ event.time }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Tomorrow Section -->
  {% if tomorrow_events and tomorrow_events.size > 0 and tomorrow_limit > 0 %}
    <div class="section-container">
      <div class="section-title">Tomorrow</div>
      <div class="event-list">
        {% for event in tomorrow_events limit:tomorrow_limit %}
          <div class="event-item">
            <div class="event-title">{{ event.title }}</div>
            <span class="time-badge">{{ event.time }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Empty State -->
  {% assign today_empty = false %}
  {% if today_events == empty or today_events == nil or today_events.size == 0 %}
    {% assign today_empty = true %}
  {% endif %}

  {% assign tomorrow_empty = false %}
  {% if tomorrow_events == empty or tomorrow_events == nil or tomorrow_events.size == 0 %}
    {% assign tomorrow_empty = true %}
  {% endif %}

  {% if today_empty and tomorrow_empty %}
    <div class="empty-state">
      <div class="empty-title">Clear Schedule</div>
      <div class="empty-desc">No events scheduled for today or tomorrow.</div>
    </div>
  {% endif %}
</div>

