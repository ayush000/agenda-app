<style>
  .section-label { text-transform: uppercase; letter-spacing: 0.1em; }
</style>

<div class="layout layout--col layout--start layout--stretch-x">
  <div class="description section-label label--gray-out">Today</div>
  <div class="divider--h"></div>
  {% if today_events and today_events.size > 0 %}
    {% for event in today_events limit:2 %}
      <div class="flex flex--row flex--between flex--center-y">
        <div class="title--large flex-auto">{{ event.title }}</div>
        <span class="label label--inverted label--large flex-none">{{ event.time }}</span>
      </div>
    {% endfor %}
  {% else %}
    <div class="flex flex--col">
      <div class="title--large section-label">Clear</div>
      <div class="description">No events today.</div>
    </div>
  {% endif %}
</div>
