<div class="p-4">
  <div class="mb-4 border-b-2 border-black pb-2">
    <h1 class="text-2xl font-black uppercase tracking-tight">Agenda</h1>
  </div>

  <div class="space-y-4">
    {% if events and events.size > 0 %}
      {% for event in events limit:6 %}
        <div>
          <div class="text-sm font-bold text-gray-500 uppercase">{{ event.time }}</div>
          <div class="text-lg font-bold leading-tight">{{ event.title }}</div>
          {% if event.location %}
            <div class="text-xs font-medium text-gray-400">@ {{ event.location }}</div>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="text-lg font-medium text-gray-500">No events.</div>
    {% endif %}
  </div>
</div>

