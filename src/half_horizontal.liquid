<style>
  .agenda-container {
    padding: 16px 20px;
    height: 100%;
    display: flex;
    gap: 24px;
    box-sizing: border-box;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  
  .column {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .section-title {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #777777;
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 4px;
    margin-bottom: 12px;
  }
  
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .event-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .event-title {
    font-size: 24px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #000000;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .event-meta {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  
  .time-badge {
    background-color: #000000;
    color: #ffffff;
    padding: 2px 6px;
    font-size: 13px;
    font-weight: 800;
    border-radius: 3px;
  }
  
  .status-badge {
    border: 2px solid #000000;
    color: #000000;
    padding: 0px 6px;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 3px;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 30px 24px;
    text-align: center;
  }
  
  .empty-title {
    font-size: 24px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 3px solid #000000;
    padding-bottom: 6px;
    margin-bottom: 10px;
    color: #000000;
  }
  
  .empty-desc {
    font-size: 14px;
    font-weight: 500;
    color: #666666;
  }
</style>

{% assign has_today = false %}
{% if today_events and today_events.size > 0 %}
  {% assign has_today = true %}
{% endif %}

{% assign has_tomorrow = false %}
{% if tomorrow_events and tomorrow_events.size > 0 %}
  {% assign has_tomorrow = true %}
{% endif %}

<div class="agenda-container">
  {% if has_today or has_tomorrow %}
    <!-- Today Column -->
    <div class="column">
      <div class="section-title">Today</div>
      <div class="event-list">
        {% if has_today %}
          {% for event in today_events limit:2 %}
            <div class="event-item">
              <div class="event-title">{{ event.title }}</div>
              <div class="event-meta">
                <span class="time-badge">{{ event.time }}</span>
                {% if event.status and event.status != 'confirmed' and event.status != 'CONFIRMED' %}
                  <span class="status-badge">{{ event.status }}</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-desc">No events scheduled.</div>
        {% endif %}
      </div>
    </div>

    <!-- Tomorrow Column -->
    <div class="column">
      <div class="section-title">Tomorrow</div>
      <div class="event-list">
        {% if has_tomorrow %}
          {% for event in tomorrow_events limit:2 %}
            <div class="event-item">
              <div class="event-title">{{ event.title }}</div>
              <div class="event-meta">
                <span class="time-badge">{{ event.time }}</span>
                {% if event.status and event.status != 'confirmed' and event.status != 'CONFIRMED' %}
                  <span class="status-badge">{{ event.status }}</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-desc">No events scheduled.</div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <!-- Empty State -->
    <div class="empty-state">
      <div class="empty-title">Clear Schedule</div>
      <div class="empty-desc">No events scheduled for today or tomorrow.</div>
    </div>
  {% endif %}
</div>
