<style>
  .section-label { text-transform: uppercase; letter-spacing: 0.1em; }
</style>

{% assign has_today = false %}
{% if today_events and today_events.size > 0 %}
  {% assign has_today = true %}
{% endif %}

{% assign has_tomorrow = false %}
{% if tomorrow_events and tomorrow_events.size > 0 %}
  {% assign has_tomorrow = true %}
{% endif %}

<div class="layout layout--row layout--start">
  {% if has_today or has_tomorrow %}
    {% if has_today and has_tomorrow %}
      <div class="column">
        <div class="description section-label label--gray-out">Today</div>
        <div class="divider--h"></div>
        {% for event in today_events limit:3 %}
          <div class="flex flex--row flex--between flex--center-y">
            <div class="title--xlarge flex-auto">{{ event.summary }}</div>
            <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
          </div>
        {% endfor %}
      </div>

      <div class="divider--v"></div>

      <div class="column">
        <div class="description section-label label--gray-out">Tomorrow</div>
        <div class="divider--h"></div>
        {% for event in tomorrow_events limit:3 %}
          <div class="flex flex--row flex--between flex--center-y">
            <div class="title--xlarge flex-auto">{{ event.summary }}</div>
            <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
          </div>
        {% endfor %}
      </div>

    {% elsif has_today %}
      <div class="column">
        <div class="description section-label label--gray-out">Today</div>
        <div class="divider--h"></div>
        {% for event in today_events limit:3 %}
          <div class="flex flex--row flex--between flex--center-y">
            <div class="title--xlarge flex-auto">{{ event.summary }}</div>
            <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
          </div>
        {% endfor %}
      </div>

      <div class="divider--v"></div>

      <div class="column">
        <div class="description section-label label--gray-out">Today (Continued)</div>
        <div class="divider--h"></div>
        {% if today_events.size > 3 %}
          {% for event in today_events limit:3 offset:3 %}
            <div class="flex flex--row flex--between flex--center-y">
              <div class="title--xlarge flex-auto">{{ event.summary }}</div>
              <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
            </div>
          {% endfor %}
        {% else %}
          <div class="description">No more events today.</div>
        {% endif %}
      </div>

    {% else %}
      <div class="column">
        <div class="description section-label label--gray-out">Tomorrow</div>
        <div class="divider--h"></div>
        {% for event in tomorrow_events limit:3 %}
          <div class="flex flex--row flex--between flex--center-y">
            <div class="title--xlarge flex-auto">{{ event.summary }}</div>
            <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
          </div>
        {% endfor %}
      </div>

      <div class="divider--v"></div>

      <div class="column">
        <div class="description section-label label--gray-out">Tomorrow (Continued)</div>
        <div class="divider--h"></div>
        {% if tomorrow_events.size > 3 %}
          {% for event in tomorrow_events limit:3 offset:3 %}
            <div class="flex flex--row flex--between flex--center-y">
              <div class="title--xlarge flex-auto">{{ event.summary }}</div>
              <span class="label label--inverted label--large flex-none">{% if event.all_day %}All day{% else %}{{ event.start }}{% endif %}</span>
            </div>
          {% endfor %}
        {% else %}
          <div class="description">No more events tomorrow.</div>
        {% endif %}
      </div>
    {% endif %}
  {% else %}
    <div class="flex flex--col">
      <div class="title--xxlarge section-label">Clear Schedule</div>
      <div class="description">No events scheduled for today or tomorrow.</div>
    </div>
  {% endif %}
</div>
